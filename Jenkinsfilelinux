pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '1'
        // Credenciais de bootstrap do Infisical, vindas do Jenkins Credentials Store.
        // NÃO ficam no repo. A CLI do Infisical (dentro do container) lê destas vars
        // para autenticar e injetar os segredos reais (DATABASE_URL, JWT_SECRET, etc).
        INFISICAL_UNIVERSAL_AUTH_CLIENT_ID     = credentials('infisical-client-id')
        INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET = credentials('infisical-client-secret')
        INFISICAL_PROJECT_ID                   = credentials('infisical-project-id')
    }

    stages {
        stage('Verificar Repositório') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    doGenerateSubmoduleConfigurations: false,
                    extensions: [],
                    submoduleCfg: [],
                    userRemoteConfigs: [[
                        url: 'https://github.com/lain77/api-usuarios-delivery.git'
                    ]]
                ])
            }
        }

        stage('Build Docker') {
            steps {
                sh 'docker compose build --no-cache'
            }
        }

        stage('Deploy') {
            steps {
                // As três credenciais do Infisical já estão no ambiente (bloco environment),
                // então o docker compose as repassa ao container via ${...} no compose.
                sh '''
                    docker compose down --remove-orphans
                    docker compose up -d
                '''
            }
        }

        stage('Verificar Containers') {
            steps {
                sh 'docker ps'
            }
        }
    }

    post {
        success {
            echo 'Deploy do microsserviço Usuário realizado com sucesso no Yacht (Linux)!'
        }
        failure {
            echo 'Houve um erro durante o deploy do microsserviço Usuário.'
        }
        always {
            sh 'docker image prune -f || true'
        }
    }
}
