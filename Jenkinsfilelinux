pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '1'
    }

    stages {
        stage('Verificar Repositorio') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    doGenerateSubmoduleConfigurations: false,
                    extensions: [],
                    submoduleCfg: [],
                    userRemoteConfigs: [[
                        url: 'https://github.com/lain77/api-usuarios-delivery.git'
                    ]]
                ])
            }
        }

        stage('Build Docker') {
            steps {
                sh 'docker compose build --no-cache'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    docker compose down --remove-orphans
                    docker compose up -d
                '''
            }
        }

        stage('Verificar Containers') {
            steps {
                sh 'docker ps'
            }
        }

        stage('Limpeza') {
            steps {
                sh 'docker image prune -f || true'
            }
        }
    }

    post {
        success {
            echo 'Deploy do microsservico Usuario realizado com sucesso no Yacht (Linux)!'
        }
        failure {
            echo 'Houve um erro durante o deploy do microsservico Usuario.'
        }
    }
}
